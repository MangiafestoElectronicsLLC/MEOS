<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="repository.meos" name="MEOS Repository" version="1.0.0" provider-name="MEOS">
  <extension point="xbmc.addon.repository" name="MEOS Repository">
    <dir>
      <info compressed="false">addons.xml</info>
      <checksum>addons.xml.md5</checksum>
      <datadir zip="true">zips</datadir>
    </dir>
  </extension>
  <extension point="xbmc.addon.metadata">
    <summary>MEOS Kodi Repository</summary>
    <description>This is the official Kodi repository for MEOS, featuring streaming and gaming add-ons.</description>
    <platform>all</platform>
    <license>MIT</license>
    <author>MEOS</author>
    <source>https://github.com/yourusername/meos-repo</source>
    <assets>
      <icon>icon.png</icon>
      <fanart>fanart.jpg</fanart>
    </assets>
    <disclaimer>Use responsibly and abide by your region's streaming regulations.</disclaimer>
    <news>Initial release of MEOS Repository.</news>
  </extension>
  <!-- Kodi version compatibility -->
  <requires>
    <kodi minversion="18.0" />
  </requires>
</addon>